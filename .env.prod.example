# ─────────────────────────────────────────────────────────────────────────────
# WhyteBox Production Environment Variables
#
# Copy this file to .env.prod and fill in all required values.
# NEVER commit .env.prod to version control.
#
# Usage:
#   cp .env.prod.example .env.prod
#   # edit .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
VERSION=1.0.0
HTTP_PORT=80
# HTTPS_PORT=443

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=whytebox
# REQUIRED: set a strong password
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=whytebox
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave empty to disable Redis auth (not recommended for production)
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# Example: https://whytebox.example.com,https://www.whytebox.example.com
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ── Frontend build ────────────────────────────────────────────────────────────
# The public-facing URL of the API as seen by the browser.
# For production with a domain: https://whytebox.example.com/api/v1
VITE_API_URL=http://localhost/api/v1

# ── ML / PyTorch ──────────────────────────────────────────────────────────────
# cpu | cuda | mps
PYTORCH_DEVICE=cpu
MODEL_CACHE_SIZE=5
MODEL_CACHE_TTL=7200
MAX_UPLOAD_SIZE=524288000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO