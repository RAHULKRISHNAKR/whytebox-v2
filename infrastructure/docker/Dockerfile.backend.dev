# WhyteBox Backend — Development Dockerfile
#
# Hot-reload via uvicorn --reload.
# Source code is bind-mounted from the host (see docker-compose.yml).
# Do NOT use this image in production.

FROM python:3.11-slim

WORKDIR /app

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    libgl1-mesa-glx \
    libglib2.0-0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps
COPY backend/requirements.txt .
COPY backend/requirements-dev.txt* ./
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt && \
    (pip install --no-cache-dir -r requirements-dev.txt 2>/dev/null || true)

# Copy application source (overridden by bind mount in docker-compose.yml)
COPY backend/ .

# Create runtime directories
RUN mkdir -p uploads models output logs

EXPOSE 8000

# Development: uvicorn with hot-reload
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]