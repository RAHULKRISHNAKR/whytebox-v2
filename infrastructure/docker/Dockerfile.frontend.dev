# WhyteBox Frontend — Development Dockerfile
#
# Vite dev server with HMR (Hot Module Replacement).
# Source code is bind-mounted from the host (see docker-compose.yml).
# Do NOT use this image in production.

FROM node:18-alpine

WORKDIR /app

# Install deps first (cached layer — only re-runs when package.json changes)
COPY frontend/package*.json ./
RUN npm ci

# Copy source (overridden by bind mount in docker-compose.yml)
COPY frontend/ .

EXPOSE 5173

# Development: Vite dev server with HMR
# --host 0.0.0.0 makes it accessible from outside the container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]