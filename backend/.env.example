# ─────────────────────────────────────────────────────────────────────────────
# WhyteBox Backend — Local Development Environment
#
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# This file is safe to commit. Never commit .env with real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no setup required for local dev)
DATABASE_URL=sqlite+aiosqlite:///./whytebox_local.db

# PostgreSQL (use this when running docker compose up)
# DATABASE_URL=postgresql+asyncpg://whytebox:password@localhost:5432/whytebox

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave empty to run without Redis (app degrades gracefully)
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=

# ── Security ──────────────────────────────────────────────────────────────────
# OK for local dev — MUST be changed for production
SECRET_KEY=local-dev-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ── ML Settings ───────────────────────────────────────────────────────────────
PYTORCH_DEVICE=cpu
MODEL_CACHE_SIZE=3
MODEL_CACHE_TTL=3600

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# ── Celery (optional — only needed for background tasks) ──────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2