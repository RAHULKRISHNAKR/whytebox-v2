{
  "name": "whytebox-frontend",
  "version": "2.0.0",
  "type": "module",
  "description": "WhyteBox - AI Model Explainability Platform Frontend",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "lint:a11y": "eslint . --ext ts,tsx --config .eslintrc.accessibility.json",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "a11y:audit": "node scripts/accessibility-audit.js",
    "a11y:audit:ci": "node scripts/accessibility-audit.js --threshold 0",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "quality:check": "npm run lint && npm run format:check && npm run type-check && npm run test:coverage"
  },
  "dependencies": {
    "@babylonjs/core": "^6.37.0",
    "@babylonjs/loaders": "^6.37.0",
    "@babylonjs/materials": "^6.37.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@reduxjs/toolkit": "^2.0.1",
    "@tanstack/react-query": "^5.14.2",
    "@tanstack/react-query-devtools": "^5.14.2",
    "autoprefixer": "^10.4.27",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "d3": "^7.8.5",
    "date-fns": "^3.0.6",
    "dompurify": "^3.0.8",
    "immer": "^10.0.3",
    "lodash-es": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-redux": "^9.0.4",
    "react-router-dom": "^6.20.0",
    "react-syntax-highlighter": "^15.5.0",
    "reactflow": "^11.10.1",
    "recharts": "^2.10.3",
    "remark-gfm": "^4.0.0",
    "socket.io-client": "^4.6.0",
    "tailwindcss": "^3.4.19",
    "web-vitals": "^5.1.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.2",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/d3": "^7.4.3",
    "@types/dompurify": "^3.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.0.4",
    "eslint": "^8.55.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-security": "^2.1.0",
    "happy-dom": "^12.10.3",
    "msw": "^2.0.11",
    "pa11y": "^8.0.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "main": "lighthouserc.js",
  "directories": {
    "doc": "docs"
  },
  "author": "",
  "license": "ISC"
}
