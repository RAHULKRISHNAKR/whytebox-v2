# ─────────────────────────────────────────────────────────────────────────────
# WhyteBox Frontend — Local Development Environment
#
# Copy this file to .env.local and edit as needed:
#   cp .env.example .env.local
#
# Vite only exposes variables prefixed with VITE_ to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Full backend API URL including /api/v1 path
# Local dev (backend running directly on port 5001 - macOS AirPlay occupies 5000):
VITE_API_URL=http://localhost:5001/api/v1

# Local dev (backend running via docker compose):
# VITE_API_URL=http://localhost:8000/api/v1

# Production (set in Vercel dashboard, not here):
# VITE_API_URL=https://whytebox-backend.onrender.com/api/v1